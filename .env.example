# ---- Telegram API credentials — get these from https://my.telegram.org ----
API_ID=123456
API_HASH=your_api_hash_here

# ---- BotFather bot token ----
BOT_TOKEN=123456:ABC-your-bot-token

# ---- Assistant session string — generate with generate_session.py ----
SESSION_STRING=your_pyrogram_session_string_here

# ---- Access control ----
OWNER_ID=your_telegram_user_id
SUDO_USERS=111111,222222
ACCESS_KEYS=free-demo:free,pro-demo:pro,ent-demo:enterprise

# ---- Optional logging group ----
LOG_GROUP_ID=

# ---- Playback tuning ----
DURATION_LIMIT_MIN=120
AUTO_LEAVE_SECONDS=300
DEFAULT_TIER=free
AUDIO_BITRATE=48k
STREAM_QUALITY=high
